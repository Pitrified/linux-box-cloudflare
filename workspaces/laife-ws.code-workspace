{
	"folders": [
		{
			"name": "linux-box-cloudflare",
			"path": ".."
		},
		{
			"name": "llm-core",
			"path": "../../llm-core"
		},
		{
			"name": "laife",
			"path": "../../laife"
		},
		{
			"name": "python-project-template",
			"path": "../../python-project-template"
		},
	],
	"settings": {
		"cSpell.words": [
			"vectorable",
			"vectorstores"
		],
		"files.exclude": {
			"**/.venv": true,
			"**/__pycache__": true,
			"**/.ruff_cache": true,
			"**/.pytest_cache": true,
			"**/.mypy_cache": true,
			"**/node_modules": true,
			"**/htmlcov": true
		},
		"search.exclude": {
			"**/.venv/**": true,
			"**/__pycache__/**": true,
			"**/.ruff_cache/**": true,
			"**/.pytest_cache/**": true,
			"**/.mypy_cache/**": true,
			"**/node_modules/**": true,
			"**/cache/**": true,
			"**/site/**": true,
			"**/htmlcov/**": true,
			"**/build/**": true,
			"**/dist/**": true
		},
		"files.watcherExclude": {
			"**/.venv/**": true,
			"**/__pycache__/**": true,
			"**/.ruff_cache/**": true,
			"**/.pytest_cache/**": true,
			"**/node_modules/**": true,
			"**/cache/**": true,
			"**/site/**": true,
			"**/build/**": true,
			"**/dist/**": true
		}
	}
}
